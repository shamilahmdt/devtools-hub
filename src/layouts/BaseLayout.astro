---
import "../styles/global.css";
import { Image } from "astro:assets";

export interface Props {
  title?: string;
  description?: string;
}

const domain = "https://devtools-hub-beryl.vercel.app";
const canonicalUrl = new URL(Astro.url.pathname, domain).toString();
const isToolPage = Astro.url.pathname.startsWith('/tools/');

const { 
  title = "DevTools Hub - The Ultimate Developer Utility Belt",
  description = "A powerful collection of essential developer tools including JSON formatters, Base64 converters, UUID generators, hash calculators, and more. Free, offline-first, and open-source."
} = Astro.props;
import Search from "../components/tool/Search";
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/icon.png" />
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#0a0a0a" />
    
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content="developer tools, json formatter, base64 encoder, jwt decoder, hash generator, uuid generator, unix timestamp converter, devtools hub, programming utilities, online developer tools" />
    <meta name="author" content="DevTools Hub" />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <link rel="canonical" href={canonicalUrl} />
    
    <meta name="google-site-verification" content="mJ6fh5_ye3KXYDnHSiFu-i_plcg2pHw6jCkdTCB9nfQ" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="/icon.png" />
    <meta property="og:site_name" content="DevTools Hub" />

    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="/icon.png" />

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      "name": title.split(' | ')[0],
      "description": description,
      "applicationCategory": "DeveloperApplication",
      "operatingSystem": "Any",
      "url": canonicalUrl,
      "offers": {
        "@type": "Offer",
        "price": "0"
      }
    })} />
  </head>

  <body class="flex min-h-screen flex-col bg-neutral-950 text-neutral-200 antialiased selection:bg-blue-500/30">
    <header class="sticky top-0 z-50 border-b border-neutral-800 bg-neutral-950/80 backdrop-blur-md">
      <div class="mx-auto flex max-w-7xl items-center justify-between gap-8 px-6 py-4">
        <a href="/" class="flex items-center gap-2 transition-opacity hover:opacity-80 shrink-0">
          <Image src="/icon.png" alt="DevToolsHub Logo" width={32} height={32} loading="eager" class="size-8" />
          <h1 class="text-xl font-bold tracking-tight text-white hidden sm:block">DevToolsHub</h1>
        </a>

        <div class="flex-1 flex justify-center">
          <Search client:load />
        </div>

        <nav class="flex items-center gap-6 shrink-0">
          <a href="https://github.com/shabeeltt/devtools-hub" class="text-sm font-medium text-neutral-400 hover:text-white">GitHub</a>
        </nav>
      </div>
    </header>

    <main class="mx-auto w-full max-w-7xl flex-1 px-6 py-12">
      {isToolPage && (
        <>
          <button
            id="dynamic-back-button"
            class="mb-6 hidden items-center gap-2 text-sm font-medium text-neutral-400 transition-colors hover:text-white group"
            onclick="window.history.back()"
          >
            <svg 
              xmlns="http://www.w3.org/2000/svg" 
              width="16" 
              height="16" 
              viewBox="0 0 24 24" 
              fill="none" 
              stroke="currentColor" 
              stroke-width="2" 
              stroke-linecap="round" 
              stroke-linejoin="round"
              class="transition-transform group-hover:-translate-x-1"
            >
              <path d="m15 18-6-6 6-6"/>
            </svg>
            Back
          </button>
          <script is:inline>
            if (document.referrer && document.referrer.includes(window.location.origin)) {
              const btn = document.getElementById('dynamic-back-button');
              if (btn) btn.style.display = 'inline-flex';
            }
          </script>
        </>
      )}
      <slot />
    </main>

    <footer class="mt-auto border-t border-neutral-800 px-6 py-8 text-right text-sm text-neutral-500">
      <p>&copy; {new Date().getFullYear()} DevToolsHub. Open source starter.</p>
    </footer>

    <script is:inline>
      // register service worker for offline pwa support
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register('/service-worker.js').catch((err) => {
            console.error('service worker registration failed:', err);
          });
        });
      }
    </script>
  </body>
</html>