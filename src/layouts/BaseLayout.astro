---
import "../styles/global.css";

const { title = "DevToolsHub" } = Astro.props;
import Search from "../components/tool/Search";
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/png" href="/icon.png" />
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#0a0a0a" />
    <title>{title}</title>
  </head>

  <body class="min-h-screen bg-neutral-950 text-neutral-200 antialiased selection:bg-blue-500/30">
    <header class="sticky top-0 z-50 border-b border-neutral-800 bg-neutral-950/80 backdrop-blur-md">
      <div class="mx-auto flex max-w-5xl items-center justify-between gap-8 px-6 py-4">
        <a href="/" class="flex items-center gap-2 transition-opacity hover:opacity-80 shrink-0">
          <img src="/icon.png" alt="DevToolsHub Logo" class="size-8" />
          <h1 class="text-xl font-bold tracking-tight text-white hidden sm:block">DevToolsHub</h1>
        </a>

        <div class="flex-1 flex justify-center">
          <Search client:load />
        </div>

        <nav class="flex items-center gap-6 shrink-0">
          <a href="https://github.com/shabeeltt/devtools-hub" class="text-sm font-medium text-neutral-400 hover:text-white">GitHub</a>
        </nav>
      </div>
    </header>

    <main class="mx-auto max-w-5xl px-6 py-12">
      <slot />
    </main>

    <footer class="border-t border-neutral-800 py-12 text-center text-sm text-neutral-500">
      <p>&copy; {new Date().getFullYear()} DevToolsHub. Open source starter.</p>
    </footer>

    <script is:inline>
      // register service worker for offline pwa support
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register('/service-worker.js').catch((err) => {
            console.error('service worker registration failed:', err);
          });
        });
      }
    </script>
  </body>
</html>