---
import "../styles/global.css";

const { title = "DevToolsHub" } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/png" href="/icon.png" />
    <title>{title}</title>
  </head>

  <body class="min-h-screen bg-neutral-950 text-neutral-200 antialiased selection:bg-blue-500/30">
    <header class="sticky top-0 z-50 border-b border-neutral-800 bg-neutral-950/80 backdrop-blur-md">
      <div class="mx-auto flex max-w-5xl items-center justify-between px-6 py-4">
        <a href="/" class="flex items-center gap-2 transition-opacity hover:opacity-80">
          <img src="/icon.png" alt="DevToolsHub Logo" class="size-8" />
          <h1 class="text-xl font-bold tracking-tight text-white">DevToolsHub</h1>
        </a>
        <nav class="flex items-center gap-6">
          <a href="https://github.com/shabeeltt/devtools-hub" class="text-sm font-medium text-neutral-400 hover:text-white">GitHub</a>
        </nav>
      </div>
    </header>

    <main class="mx-auto max-w-5xl px-6 py-12">
      <slot />
    </main>

    <footer class="border-t border-neutral-800 py-12 text-center text-sm text-neutral-500">
      <p>&copy; {new Date().getFullYear()} DevToolsHub. Open source starter.</p>
    </footer>
  </body>
</html>