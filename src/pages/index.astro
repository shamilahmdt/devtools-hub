---
import BaseLayout from "../layouts/BaseLayout.astro";
import { tools } from "../constants/tools";
---

<BaseLayout 
  title="DevTools Hub | Essential Free Developer Tools & Utilities"
  description="Your ultimate online developer utility belt. Instantly format JSON, decode Base64, generate UUIDs, and more in a fast, free, offline-ready web app."
>
  <div class="mb-12">
    <h2 class="text-3xl font-bold text-white tracking-tight mb-2">
      Available Tools
    </h2>
    <p class="text-neutral-400">
      Essential utilities to boost your productivity.
    </p>
  </div>

  <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
    {
      tools.map((tool) => (
        <a
          href={tool.href}
          class="group relative overflow-hidden rounded-xl border border-neutral-800 bg-neutral-900 p-6 transition-all hover:border-blue-500/50 hover:bg-neutral-800/50"
        >
          <div
            class="mb-4 inline-flex size-10 items-center justify-center rounded-lg bg-blue-500/10 text-blue-500 group-hover:bg-blue-500 group-hover:text-white transition-colors"
            set:html={tool.icon}
          />

          <h3 class="text-lg font-semibold text-white mb-2">{tool.name}</h3>

          <p class="text-sm text-neutral-400">{tool.description}</p>
        </a>
      ))
    }
  </div>
</BaseLayout>
